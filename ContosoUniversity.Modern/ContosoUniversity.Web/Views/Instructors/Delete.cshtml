@model ContosoUniversity.Web.Models.InstructorViewModel

@{
    ViewData["Title"] = "Delete Instructor";
}

<h2>Delete Instructor</h2>
<div class="alert alert-danger">
    <h3>Are you sure you want to delete this instructor?</h3>
</div>
<hr />

<div>
    <dl class="row">
        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.LastName)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.LastName)</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.FirstName)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.FirstName)</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.HireDate)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.HireDate)</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.OfficeLocation)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.OfficeLocation)</dd>
    </dl>

    @if (Model.AssignedCourses != null && Model.AssignedCourses.Any())
    {
        <div class="alert alert-warning mt-3">
            <p><strong>Warning:</strong> This instructor is teaching the following courses:</p>
            <ul>
                @foreach (var course in Model.AssignedCourses)
                {
                    <li>@course.CourseID: @course.Title</li>
                }
            </ul>
            <p>These course assignments will be removed if you delete this instructor.</p>
        </div>
    }

    <form asp-action="Delete" method="post" class="mt-3">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>
