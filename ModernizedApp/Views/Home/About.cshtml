@{
    ViewData["Title"] = "About";
}

<h1>About Classic ASP Store</h1>

<div class="about-content">
    <p>Welcome to Classic ASP Store, a demonstration of modern ASP.NET Core technology.</p>
    
    <h2>Our Story</h2>
    <p>Classic ASP Store was originally created as a demonstration project using Classic ASP technology. It has now been modernized to ASP.NET Core, showcasing the capabilities of modern web development with .NET.</p>
    
    <h2>Our Mission</h2>
    <p>Our mission is to provide a simple, working example of an ASP.NET Core e-commerce application that developers can learn from and extend.</p>
    
    <h2>Technology</h2>
    <p>This store is built using:</p>
    <ul>
        <li>ASP.NET Core 8.0 MVC</li>
        <li>C# programming language</li>
        <li>Entity Framework Core with SQL Server</li>
        <li>Bootstrap 5 for responsive design</li>
        <li>Azure App Service for cloud hosting</li>
    </ul>
</div>

@section Styles {
    <style>
        .about-content {
            line-height: 1.8;
            background-color: #fff;
            border-radius: 8px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
            padding: 30px;
            margin-bottom: 30px;
        }
        
        .about-content h2 {
            margin-top: 25px;
            margin-bottom: 15px;
            border-bottom: 1px solid #eee;
            padding-bottom: 10px;
            color: #3498db;
        }
        
        .about-content ul {
            margin-left: 20px;
            margin-bottom: 20px;
        }
    </style>
}
