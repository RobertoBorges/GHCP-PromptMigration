@model PartsUnlimited.Models.Product

<div class="alert alert-new-arrival @(Model == null ? "hidden" : "")" id="alert-new-arrival" role="alert">
    <div class="container">
        <div class="alert-content">
            <span class="glyphicon glyphicon-bullhorn"></span>
            @if (Model == null)
            {
                <a id="new-arrival" href="#"></a>
            }
            else
            {
                <a id="new-arrival" asp-controller="Store" asp-action="Details" asp-route-id="@Model.ProductId">@string.Format(" New Arrival : {0}", Model.Title)</a>
            }
        </div>
    </div>
</div>
