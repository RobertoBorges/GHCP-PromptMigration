{
  "name": "azure-migration-squad-vscode",
  "displayName": "Azure Migration Agent",
  "description": "Migrate any application to Azure with GitHub Copilot. Universal source/stack/workload coverage (15 source adapters, 15 stack adapters, 9 workload patterns). Discovery-first workflow. Hard-stop user-decision gates so the agent never picks framework/database/hosting on your behalf.",
  "version": "0.3.0",
  "publisher": "robertoborges",
  "private": false,
  "license": "MIT",
  "icon": "media/icon.png",
  "homepage": "https://github.com/RobertoBorges/GHCP-PromptMigration",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RobertoBorges/GHCP-PromptMigration.git",
    "directory": "packages/azure-migration-squad-vscode"
  },
  "bugs": {
    "url": "https://github.com/RobertoBorges/GHCP-PromptMigration/issues"
  },
  "categories": [
    "Other",
    "Azure",
    "AI"
  ],
  "keywords": [
    "azure",
    "migration",
    "copilot",
    "ai",
    "modernization",
    "dotnet",
    "java",
    "python",
    "nodejs"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "azureMigrationSquad",
          "title": "Azure Migration Agent",
          "icon": "media/activity-bar-icon.svg"
        }
      ]
    },
    "views": {
      "azureMigrationSquad": [
        {
          "id": "azureMigrationSquadDecisions",
          "name": "🛑 Decisions Required",
          "icon": "media/activity-bar-icon.svg",
          "contextualTitle": "Azure Migration Agent — Decisions Required"
        },
        {
          "id": "azureMigrationSquadAgents",
          "name": "Agent",
          "icon": "media/activity-bar-icon.svg",
          "contextualTitle": "Azure Migration Agent — Definition"
        },
        {
          "id": "azureMigrationSquadPrompts",
          "name": "🟢 Main path (Assess + Phase 1-6)",
          "icon": "media/activity-bar-icon.svg",
          "contextualTitle": "Azure Migration Agent — Main path"
        },
        {
          "id": "azureMigrationSquadAddons",
          "name": "🔵 Optional add-ons",
          "icon": "media/activity-bar-icon.svg",
          "contextualTitle": "Azure Migration Agent — Optional add-ons"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "azureMigrationSquad.refreshTree",
          "when": "view == azureMigrationSquadAgents || view == azureMigrationSquadPrompts || view == azureMigrationSquadAddons || view == azureMigrationSquadDecisions",
          "group": "navigation"
        }
      ]
    },
    "walkthroughs": [
      {
        "id": "azureMigrationSquadGettingStarted",
        "title": "Migrate to Azure with the Azure Migration Agent",
        "description": "Set up the agent, then run the main path (Phase 1 → Phase 6) to migrate your application.",
        "steps": [
          {
            "id": "install",
            "title": "Initialize the migration agent in your workspace",
            "description": "Drops the agent definition, prompts, skills, and a 60-second quickstart into your project.\n[Initialize now](command:azureMigrationSquad.initialize)",
            "media": {
              "image": "media/walkthroughs/step-1-init.png",
              "altText": "Initialize Azure Migration Agent screenshot"
            },
            "completionEvents": [
              "onCommand:azureMigrationSquad.initialize"
            ]
          },
          {
            "id": "installCopilot",
            "title": "Install GitHub Copilot Chat",
            "description": "The agent uses slash commands inside Copilot Chat (e.g. `/assess-any-application`). If you already have Copilot Chat installed, this step auto-completes.\n[Install Copilot Chat](command:azureMigrationSquad.installCopilotChat)",
            "media": {
              "image": "media/walkthroughs/step-2-copilot.png",
              "altText": "Install GitHub Copilot Chat extension"
            },
            "completionEvents": [
              "extensionInstalled:GitHub.copilot-chat"
            ]
          },
          {
            "id": "discovery",
            "title": "Start the main path — /assess-any-application",
            "description": "Step 1 of the main path is Discovery. Interviews you about source, stack, workload, data, and integrations; produces the Capability Matrix that /Phase1-Plan and every subsequent phase consumes.\n[Start main path](command:azureMigrationSquad.openMainPath)",
            "media": {
              "image": "media/walkthroughs/step-3-discovery.png",
              "altText": "Run /assess-any-application in Copilot Chat"
            },
            "completionEvents": [
              "onCommand:azureMigrationSquad.openMainPath"
            ]
          },
          {
            "id": "explore",
            "title": "Explore the sidebar — Agent, Main path, Add-ons, Decisions",
            "description": "Look for the rocket icon 🚀 in the Activity Bar. Browse the agent, the 6 main-path phases, optional add-ons grouped by purpose, and pending architecture decisions. Click any item to open its source file.",
            "media": {
              "image": "media/walkthroughs/step-4-sidebar.png",
              "altText": "Azure Migration Agent sidebar"
            }
          }
        ]
      }
    ],
    "configuration": {
      "title": "Azure Migration Agent",
      "properties": {
        "azureMigrationSquad.autoInstallCopilot": {
          "type": "string",
          "default": "prompt",
          "enum": [
            "prompt",
            "auto",
            "never"
          ],
          "enumDescriptions": [
            "Ask once per workspace before installing the GitHub Copilot Chat extension.",
            "Install GitHub Copilot Chat automatically without asking.",
            "Never offer to install GitHub Copilot Chat."
          ],
          "description": "Behavior when GitHub Copilot Chat is not installed. The Azure Migration Agent uses Copilot Chat slash commands.",
          "scope": "application"
        },
        "azureMigrationSquad.statusBar.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show the current migration phase and pending decisions in the status bar.",
          "scope": "window"
        }
      }
    },
    "commands": [
      {
        "command": "azureMigrationSquad.initialize",
        "title": "Initialize in this workspace",
        "category": "Azure Migration",
        "icon": "$(rocket)"
      },
      {
        "command": "azureMigrationSquad.upgrade",
        "title": "Upgrade to latest version",
        "category": "Azure Migration",
        "icon": "$(cloud-download)"
      },
      {
        "command": "azureMigrationSquad.doctor",
        "title": "Run health check (doctor)",
        "category": "Azure Migration",
        "icon": "$(pulse)"
      },
      {
        "command": "azureMigrationSquad.openMainPath",
        "title": "Start main path (/assess-any-application)",
        "category": "Azure Migration",
        "icon": "$(play)"
      },
      {
        "command": "azureMigrationSquad.openDiscovery",
        "title": "Open Discovery (/assess-any-application)",
        "category": "Azure Migration",
        "icon": "$(search)"
      },
      {
        "command": "azureMigrationSquad.showCatalog",
        "title": "Show prompt catalog (MIGRATION-START-HERE.md)",
        "category": "Azure Migration",
        "icon": "$(book)"
      },
      {
        "command": "azureMigrationSquad.openSettings",
        "title": "Open settings",
        "category": "Azure Migration",
        "icon": "$(settings-gear)"
      },
      {
        "command": "azureMigrationSquad.refreshTree",
        "title": "Refresh",
        "category": "Azure Migration",
        "icon": "$(refresh)"
      },
      {
        "command": "azureMigrationSquad.openFile",
        "title": "Open file (internal)",
        "category": "Azure Migration",
        "enablement": "false"
      },
      {
        "command": "azureMigrationSquad.showWelcome",
        "title": "Show welcome page",
        "category": "Azure Migration",
        "icon": "$(home)"
      },
      {
        "command": "azureMigrationSquad.installCopilotChat",
        "title": "Install GitHub Copilot Chat",
        "category": "Azure Migration",
        "icon": "$(extensions)"
      },
      {
        "command": "azureMigrationSquad.showDecisions",
        "title": "Show decisions required (open file)",
        "category": "Azure Migration",
        "icon": "$(checklist)"
      },
      {
        "command": "azureMigrationSquad.openDecisionAtLine",
        "title": "Open decision at line (internal)",
        "category": "Azure Migration",
        "enablement": "false"
      },
      {
        "command": "azureMigrationSquad.hello",
        "title": "Hello (smoke test)",
        "category": "Azure Migration"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run sync && npm run build",
    "sync": "node scripts/sync-templates.mjs",
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "lint": "echo 'lint deferred to follow-up'",
    "pretest": "npm run sync && npm run build && npm run build:tests",
    "build:tests": "tsc -p tsconfig.test.json",
    "test": "node ./out/test/runTest.js",
    "prepackage": "npm run sync",
    "package": "vsce package --no-dependencies",
    "publish": "vsce publish --no-dependencies",
    "release:local": "node scripts/local-release.mjs",
    "release:local:patch": "node scripts/local-release.mjs --patch",
    "release:local:minor": "node scripts/local-release.mjs --minor",
    "release:local:major": "node scripts/local-release.mjs --major",
    "release:local:dry-run": "node scripts/local-release.mjs --dry-run"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.3.9",
    "@vscode/vsce": "^2.24.0",
    "esbuild": "^0.20.2",
    "mocha": "^10.3.0",
    "typescript": "^5.3.3"
  }
}
