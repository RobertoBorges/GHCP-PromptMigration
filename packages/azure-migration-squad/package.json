{
  "name": "@robertoborges/azure-migration-squad",
  "version": "0.1.0-insider.7",
  "description": "Azure migration agents for GitHub Copilot + Squad. Any source. Any stack. One command.",
  "type": "module",
  "bin": {
    "azure-migration-squad": "bin/cli.js",
    "ams": "bin/cli.js"
  },
  "exports": {
    ".": {
      "import": "./bin/cli.js"
    },
    "./schemas/capability-matrix": "./schemas/capability-matrix.schema.json",
    "./schemas/discovery-dossier": "./schemas/discovery-dossier.schema.json"
  },
  "files": [
    "bin",
    "lib",
    "schemas",
    "templates",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "presync": "node scripts/clean-templates.mjs",
    "sync": "node scripts/sync-from-root.mjs",
    "prebuild": "npm run sync",
    "build": "node scripts/validate-build.mjs",
    "test": "node --test test/install.test.mjs test/eval-suite.test.mjs",
    "test:install": "node --test test/install.test.mjs",
    "test:eval": "node --test test/eval-suite.test.mjs",
    "lint": "node scripts/lint.mjs",
    "prepack": "npm run build",
    "smoke": "node test/install.test.mjs"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public",
    "tag": "insider",
    "registry": "https://registry.npmjs.org/"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RobertoBorges/GHCP-PromptMigration.git",
    "directory": "packages/azure-migration-squad"
  },
  "homepage": "https://github.com/RobertoBorges/GHCP-PromptMigration#readme",
  "bugs": {
    "url": "https://github.com/RobertoBorges/GHCP-PromptMigration/issues"
  },
  "author": "Roberto Borges",
  "keywords": [
    "azure",
    "migration",
    "copilot",
    "squad",
    "cli",
    "multi-agent",
    "modernization",
    "discovery"
  ]
}
