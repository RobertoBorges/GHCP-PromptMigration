{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/RobertoBorges/GHCP-PromptMigration/schemas/discovery-dossier.schema.json",
  "title": "Discovery Dossier (front-matter)",
  "description": "Schema for the YAML front-matter block of reports/Discovery-Dossier.md. The body of the dossier is free-form Markdown.",
  "type": "object",
  "required": ["application", "produced_by", "date", "status"],
  "properties": {
    "application": {
      "type": "string",
      "minLength": 1,
      "description": "Application name from the Capability Matrix"
    },
    "produced_by": {
      "type": "string",
      "default": "Discovery Engineer (Saul Bloom Jr.)"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "status": {
      "enum": ["Draft", "Approved by Architect", "Refined"]
    },
    "capability_matrix_path": {
      "type": "string",
      "default": "reports/Capability-Matrix.yaml"
    },
    "evidence_confidence_summary": {
      "type": "object",
      "properties": {
        "source": { "enum": ["high", "medium", "low"] },
        "stack": { "enum": ["high", "medium", "low"] },
        "workload": { "enum": ["high", "medium", "low"] },
        "data": { "enum": ["high", "medium", "low"] }
      }
    },
    "open_questions_count": { "type": "integer", "minimum": 0 },
    "risk_flag_count": { "type": "integer", "minimum": 0 }
  }
}
